FARCASTER_MCP_URL=http://sidelineiq-mcp-servers.railway.internal:3101/mcp
TWITTER_MCP_URL=http://sidelineiq-mcp-servers.railway.internal:3102/mcp
WEB_MCP_URL=https://sidelineiq-mcp-servers-production.up.railway.app/mcp
# Sent as `Authorization: Bearer <secret>` on every MCP request to the
# farcaster/twitter/web servers above. Must match MCP_AUTH_SECRET set in the
# sidelineiq-mcp-servers deployment(s). Servers fail closed (503) without it.
MCP_AUTH_SECRET=
PORT=3100
MD_REVIEW_CONFIDENCE_THRESHOLD=0.75
ORTHOIQ_REFERRAL_URL=https://orthoiq.com?ref=sidelineiq

# Anthropic API key for classifier + agent Claude calls
ANTHROPIC_API_KEY=

# Shared secret for the /admin/* endpoints (approve, promote, roster-sync).
# Server-to-server only: the frontend forwards this as `Authorization: Bearer <secret>`
# on its admin route handlers. Must match AGENTS_API_SECRET set in the frontend (Vercel).
# Fail-closed — if unset, /admin/* returns 503.
AGENTS_API_SECRET=

# Autonomous polling loop configuration
# Set POLLING_ENABLED=false to disable the loop (e.g. for local dev or migrations)
POLLING_ENABLED=true
# Poll cadence in milliseconds (default: 15 minutes)
POLL_INTERVAL_MS=900000
# Per-sport toggles — launch order is NFL first, others opt-in as they stabilize
POLL_NFL=true
POLL_NBA=false
POLL_PREMIER_LEAGUE=false
POLL_UFC=false
# Max age of injury events to process (days). Filters out IR/stale listings.
# Tighten during active season (e.g. 2), relax during offseason (default: 7)
MAX_EVENT_AGE_DAYS=7
# Injury Thread Manager: pre-OTM date-resolution loop (native web_search fallback).
# Opt-in (default off) — set to 'true' once validated. Adds up to two Claude calls
# per unresolved event before OTM. Requires the mcp web server (migration 014) live.
DATE_RESOLUTION_ENABLED=false

# NewsAPI (secondary NFL source for cross-validation with ESPN).
# Free tier: 100 req/day. Default N=6 → ~16 req/day for NFL, leaving headroom
# for future sports. Hard floor of N=4 enforced in code (max 24 req/day).
NEWSAPI_KEY=
NEWSAPI_POLL_EVERY_N_CYCLES=6

# X (Twitter) insider source — curated allowlist of sports-insider timelines,
# read via X's own official MCP server (not the sidelineiq-mcp-servers gateway
# used by TWITTER_MCP_URL above). Read-only. See src/config/x-insiders.ts.
X_API_MCP_URL=https://api.x.com/mcp
# X's own app-only bearer token (read-only scope) — distinct from
# MCP_AUTH_SECRET, which authenticates only to sidelineiq's own gateway servers.
X_API_MCP_BEARER_TOKEN=
# Kill switch — disable X insider polling without a redeploy.
X_INSIDER_SOURCE_ENABLED=true
# Force every X-sourced event to MD review regardless of classifier confidence
# (defense against insider-account impersonation, which text-quality scoring
# alone would not catch). Leave true; only disable once trust in the source
# is well established.
X_INSIDER_FORCE_MD_REVIEW=true
# Max tweets fetched per insider per poll cycle.
X_INSIDER_MAX_RESULTS_PER_USER=5
# Poll every Nth cycle (default 1 = every 15-minute cycle).
X_INSIDER_POLL_EVERY_N_CYCLES=1
# Overrides the X MCP tool name used for timeline lookups — confirm the real
# name against the live server's tools/list before go-live; X's tool names
# are auto-generated from their OpenAPI spec and not fully documented.
X_API_TIMELINE_TOOL_NAME=getUsersIdTweets

# Return Watch — minimum days a desk_post must have been PUBLISHED before new
# entity activity (a status change or resolution) can propose a follow-up
# ("Return Watch") candidate. See src/monitoring/return-watch.ts.
RETURN_WATCH_MIN_DAYS_SINCE_PUBLISH=14

# IndexNow — SEO ping after each published post
# Generate a key (e.g. a UUID without dashes) and host it at https://{SITE_URL}/{key}.txt
# Update SITE_URL when a custom domain is purchased — no code changes needed
INDEXNOW_KEY=
SITE_URL=https://sidelineiq.vercel.app
